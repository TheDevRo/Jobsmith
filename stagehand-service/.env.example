# ─── LM Studio (OpenAI-compatible) ───────────────────────────────────────────
# The base URL of your LM Studio server
LM_STUDIO_BASE_URL=http://192.168.1.7:1234/v1
# API key (LM Studio accepts any non-empty value)
LM_STUDIO_API_KEY=lm-studio
# Active model name — must match what is loaded in LM Studio
LM_STUDIO_MODEL=qwen2.5-7b-instruct-1m
# Temperature for form-fill / Q&A inference
LM_STUDIO_TEMPERATURE=0.2
# Max tokens for Q&A answers
LM_STUDIO_MAX_TOKENS=1024

# ─── Skyvern (self-hosted) ────────────────────────────────────────────────────
SKYVERN_BASE_URL=http://localhost:8000
# Skyvern API key (set in Skyvern's own config)
SKYVERN_API_KEY=skyvern-key
# Seconds to wait for a Skyvern task to complete before giving up
SKYVERN_TIMEOUT_SECONDS=300

# ─── Browser ─────────────────────────────────────────────────────────────────
# true = no GUI (headless), false = show browser window
HEADLESS=true

# ─── Screenshots ─────────────────────────────────────────────────────────────
# Must be reachable by the Python backend (shared path)
SCREENSHOTS_DIR=../data/screenshots

# ─── SQLite (shared with Python backend) ─────────────────────────────────────
DB_PATH=../data/jobsmith.db

# ─── Service ─────────────────────────────────────────────────────────────────
PORT=3741
# Max ms to allow a single /apply request before timing out
APPLY_TIMEOUT_MS=600000

# ─── Retry / Stagehand ───────────────────────────────────────────────────────
# How many Stagehand retries before escalating to Skyvern
STAGEHAND_MAX_RETRIES=2
