# Jobsmith — Environment Variables
# Copy this file to .env and adjust values as needed.

# Feature flag: use Browser-Use agent for auto-apply instead of built-in Playwright logic.
# Set to "true" to enable. Default is "false" (uses existing handlers).
USE_BROWSER_USE=false

# Browser-Use persistent browser profile directory.
# Sessions (cookies, localStorage) persist here across runs.
BROWSER_PROFILE_DIR=.browser-profile

# Directory for per-domain session storageState JSON files.
SESSIONS_DIR=sessions

# Directory for failure screenshots captured by Browser-Use agent.
FAILED_SCREENSHOTS_DIR=failed_screenshots

# Run browser in headless mode (true) or visible (false).
# Set to false for debugging or first-time session setup.
BROWSER_HEADLESS=true

# Maximum number of Browser-Use agent steps before giving up on a single application.
BROWSER_USE_MAX_STEPS=50

# ── Config overrides (mainly for Docker) ─────────────────────────────────────
# These override the corresponding keys in config.yaml when set and non-empty.
# Note: a per-tier base_url/api_key inside config.yaml's ai.tiers still beats
# the env-overridden default — that's intentional.

# Overrides ai.base_url (OpenAI-compatible endpoint, e.g. LM Studio).
# From inside Docker, "host.docker.internal" reaches the host machine.
#JOBSMITH_AI_BASE_URL=http://host.docker.internal:1234/v1

# Overrides ai.api_key.
#JOBSMITH_AI_API_KEY=lm-studio

# Overrides flaresolverr.url (Cloudflare solver used by the Indeed scraper).
#JOBSMITH_FLARESOLVERR_URL=

# ── Docker headed mode (noVNC) ───────────────────────────────────────────────
# Set BROWSER_HEADLESS=false (above) to enable headed browsers inside the
# container, then open http://127.0.0.1:6080/vnc.html to see and drive them —
# this is how interactive LinkedIn/Indeed logins work in Docker.

# Host interface the noVNC port binds to. Loopback-only by default; set to
# 0.0.0.0 to reach it from other machines on your network (the VNC session
# holds logged-in job-site cookies — only do this on a network you trust).
#NOVNC_BIND=127.0.0.1

# Optional VNC password. Empty means no password (fine for loopback-only).
#VNC_PASSWORD=
