{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Jobsmith",
  "version": "0.1.0",
  "identifier": "com.thedevro.jobsmith",
  "build": {
    "frontendDist": "../packaging/splash",
    "devUrl": "http://localhost:8888"
  },
  "app": {
    "windows": [
      {
        "title": "Jobsmith",
        "width": 1440,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "externalBin": ["binaries/jobsmith-backend"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
