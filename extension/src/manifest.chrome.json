{
  "manifest_version": 3,
  "name": "Jobsmith Assist",
  "version": "0.2.3",
  "description": "Scan, autofill, and attach tailored resumes for the job tab you're on.",
  "permissions": ["storage", "activeTab", "scripting", "webNavigation", "cookies"],
  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://*.linkedin.com/*",
    "https://*.indeed.com/*"
  ],
  "optional_host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost/assist/launch/*",
        "http://127.0.0.1/assist/launch/*"
      ],
      "js": ["common/storage.js", "common/handshake.js", "assist_handshake.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["sidepanel.html"],
      "matches": ["http://*/*", "https://*/*"]
    }
  ],
  "options_ui": {
    "page": "popup.html",
    "open_in_tab": true
  },
  "action": {
    "default_title": "Jobsmith",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
