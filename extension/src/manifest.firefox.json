{
  "manifest_version": 3,
  "name": "Jobsmith Assist",
  "version": "0.2.0",
  "description": "Scan, autofill, and attach tailored resumes for the job tab you're on.",
  "permissions": ["storage", "activeTab", "scripting", "webNavigation", "cookies"],
  "host_permissions": [
    "http://localhost:8888/*",
    "http://127.0.0.1:8888/*",
    "https://*.linkedin.com/*",
    "https://*.indeed.com/*",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost:8888/assist/launch/*",
        "http://127.0.0.1:8888/assist/launch/*"
      ],
      "js": ["assist_handshake.js"],
      "run_at": "document_end"
    }
  ],
  "options_ui": {
    "page": "popup.html",
    "open_in_tab": true
  },
  "action": {
    "default_title": "Jobsmith",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "sidebar_action": {
    "default_title": "Jobsmith",
    "default_panel": "sidepanel.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "jobsmith@localhost",
      "strict_min_version": "115.0"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
