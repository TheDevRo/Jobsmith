{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jobsmith.app/sync/change-record.schema.json",
  "title": "Change record",
  "description": "One line of a changes/{deviceId}.jsonl log: a single version of one record.",
  "type": "object",
  "required": ["v", "entity", "id", "updated_at", "device", "deleted"],
  "properties": {
    "v": { "type": "integer", "minimum": 1 },
    "entity": { "enum": ["job", "application", "answer", "profile"] },
    "id": { "type": "string", "minLength": 1 },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "RFC3339 UTC, millisecond precision. The LWW clock."
    },
    "device": { "type": "string", "minLength": 1 },
    "deleted": { "type": "boolean" },
    "data": {
      "type": "object",
      "description": "Record payload. Absent/ignored when deleted=true. Unknown keys must be preserved verbatim."
    }
  },
  "allOf": [
    {
      "if": { "properties": { "deleted": { "const": false } } },
      "then": { "required": ["data"] }
    }
  ],
  "additionalProperties": false
}
